# .rhi-boundary-allow
# RHI boundary guard exemption list.
# Format: <category>: <path-prefix>
# Lines starting with '#' are comments; blank lines are ignored.
# The path-prefix (right of ':') is matched against relative file paths
# using startswith(). All paths use forward slashes.
#
# Decisions: D-04 (independent manifest file), D-05 (exemption scope).
# See .planning/phases/01-boundary-guard-baseline/01-CONTEXT.md for rationale.

# =======================================================================
# Phase 7 milestone freeze — 2026-06-09
# All entries below have been audited and carry permanent justification.
# No silent additions permitted after this point.
# To add an exemption: requires explicit review + justification comment.
# =======================================================================

# --- Backend implementations -----------------------------------------------
# These directories ARE the Vulkan/D3D12/Metal implementations — native API
# usage is their explicit job. Not violations.
backend_impl: rhi/vulkan/
backend_impl: rhi/d3d12/
backend_impl: rhi/metal/

# --- Format bridge (render layer) ---------------------------------------------
# RHIFormatBridge.h is the deliberate VkFormat <-> rhi::TextureFormat seam.
# Its sole job is format translation inside the render layer; VK_FORMAT_* tokens
# here are structural (mapping table), not violations (D-02, Phase 2 Wave 1).
render_bridge: render/RHIFormatBridge.h

# --- Debug bridge -------------------------------------------------------------
# ImGui Vulkan backend adapter requires native VkDevice/VkInstance handles.
# This is a direct platform interop file, not business logic.
debug_bridge: render/passes/GPUDrivenImguiPass.cpp
# DebugInteropBridge: sanctioned ImGui/Tracy native exception (D-08/D-09).
# All VkDevice/VkDescriptorPool/ImGui_ImplVulkan_* calls are confined here.
debug_bridge: render/DebugInteropBridge.cpp

# --- Interop cast sites (D-07) -----------------------------------------------
# These render/ files use static_cast<VulkanDevice&> / static_cast<VulkanDeviceInterop&>
# to access typed native handles (D-07 sanctioned path, replaces public escape getters).
# Each include of rhi/vulkan/VulkanDevice.h here is intentional backend interop, not
# a public API leak.
interop_cast: render/GPUDrivenRenderer.cpp
interop_cast: render/LightResources.cpp
interop_cast: render/SceneResources.cpp

# --- RHI migration residual (Wave 8/9 cleanup targets) -----------------------
# These render/ and loader/ files retain direct Vulkan includes and Vk* token
# usage from pre-migration code. They are Wave 9 / 9.5 termination targets in
# rhi-migration-plan.md — the v1 milestone acceptance does not require full
# cleanup of these files (Phase 2-6 cleaned the primary escape paths; these
# are secondary structural dependencies).
# Audited at Phase 7 freeze: each file carries native usage for reasons documented
# below. Any violation REDUCTION is welcome; additions require explicit review.
#
# render/RenderDevice.cpp / .h — VkFormat residual cleared in Phase 2 Wave C (02-03).
# Remaining Vk* usage (VkQueryPool, VkFence, VkSampler, VkCommandPool) are
# Wave 9 targets outside this milestone scope. Exemption retained for those.
# RDEV-03/RDEV-04 completed: selectSwapchainImageFormat/toVkFormat/string_VkFormat removed.
rhi_migration_residual: render/RenderDevice.cpp
rhi_migration_residual: render/RenderDevice.h
#
#
# render/MeshPool.cpp — shared vertex/index arena; partially handle-ized in Wave 8
# (getSharedVertex/IndexBufferRHIHandle). Residual VulkanCommon.h for realloc ops.
rhi_migration_residual: render/MeshPool.cpp
#
# render/UploadUtils.cpp — upload utility helpers; uses VulkanCommon.h for
# VkBufferImageCopy / layout barriers in texture upload paths. Wave 9 target.
rhi_migration_residual: render/UploadUtils.cpp
#
# loader/Ktx2Loader.cpp — KTX2 texture loader; uses VkFormat enum to parse the
# KTX2 file header vkFormat field (file format spec; not a runtime Vulkan call).
# This is a file-format read of a Vulkan-defined enum, not a backend dependency.
rhi_migration_residual: loader/Ktx2Loader.cpp

# --- Build artifacts / shader autogen ----------------------------------------
# These are generated files, not authored source. Hard-excluded by EXCLUDE_PATTERNS
# too, but listed here for clarity.
generated: _autogen/
generated: android/app/.cxx/
